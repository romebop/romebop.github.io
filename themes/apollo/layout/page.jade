extends partial/layout

block site_title
    != page.title + " · " + config.title

block description
    - desc = page.desc || page.title + ' - ' + config.author;
    meta(name="description", content=desc)

block container
    include mixins/post
    case page.title
        when 'About'
            +about(page)
        when 'Projects'
            +projects(page)

block copyright
    include partial/copyright